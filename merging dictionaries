dict1= {'a':1,'b':2}
dict2= {'c':3,'d':4}
print("Using unpacking method")
Merged2 = {**dict1,**dict2}
print(Merged2)

print("Using update()")
Merged3 = {}
Merged3.update(dict1)
Merged3.update(dict2)
print(Merged3)

print("Using loop")
for key, value in dict2.items():
    dict1[key] = value
print(dict1)
