def AddKey(dict1):
    key = input("Enter new key: ")
    value = int(input("Enter value: "))
    dict1[key] = value
    return dict1
dict1 = {}
n = int(input("Number of items:"))
for i in range(n):
    key = input("Enter key: ")
    value = int(input("Enter value: "))
    dict1[key] = value
dict1=dict(sorted(dict1.items(),key=lambda x:x[1]))
print("Ascending:",dict1)
dict1 = AddKey(dict1)
dict1=dict(sorted(dict1.items(),key=lambda x:x[1],reverse=True))
print("Descending:",dict1)
